    "402115e4fceae8db": {
      "id": "402115e4fceae8db",
      "text": "### Code Quality Standards\n1. **Basic** - Functional correctness only\n2. **Standard** - + Error handling + Documentation\n3. **Production** - + Security + Performance + Tests\n4. **Enterprise** - All standards + compliance + auditing",
      "source": "skills/code-generation-analysis/SKILL.md",
