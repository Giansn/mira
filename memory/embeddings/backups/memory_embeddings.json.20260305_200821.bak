    "581e371b49dc9117": {
      "id": "581e371b49dc9117",
      "text": "### Method 1: Direct SSH + Claude",
      "source": "skills/external-terminal-access/SKILL.md",
      "line_start": 137,
      "line_end": 148,
      "timestamp": "2026-03-05T18:58:04.310460",
