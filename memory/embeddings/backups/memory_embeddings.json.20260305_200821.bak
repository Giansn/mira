    "186d1cbb4dc5e6a3": {
      "id": "186d1cbb4dc5e6a3",
      "text": "### Method 2: Termius Multiplayer\n1. Share Termius link with connection details\n2. Others join via Termius app\n3. Shared terminal session\n4. Run `claude` in shared terminal",
      "source": "skills/external-terminal-access/SKILL.md",
      "line_start": 149,
      "line_end": 154,
