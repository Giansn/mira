      "source": "skills/acp-agent-protocol/SKILL.md",
      "line_start": 136,
      "line_end": 149,
      "timestamp": "2026-03-05T18:58:04.311671",
      "embedding_shape": [
        384
      ]
    },
    "729f8914ae24b9cb": {
      "id": "729f8914ae24b9cb",
