# OpenClaw Workspace .gitignore

# Logs
logs/
*.log
/tmp/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
.env
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# OpenClaw specific
media/
.cache/
.clawhub/lock.json

# Temporary files
*.tmp
*.temp

# Audio/video files
*.mp3
*.wav
*.ogg
*.mp4

# Data files
*.jsonl
*.csv
*.db
*.sqlite

# Configuration (except example configs)
config/
*.config.json
credentials.json

# Memory visualization data
memory-viz/data/
memory-viz/venv/

# Simulation outputs
simulations/output/

# Session manager data
session-manager/session-map.json

# Debug and test scripts (temporary development files)
/debug_*.py
/test_*.py
/test_*.sh
/test_*.json
/test_*.html
/check_*.py
/delete_*.py
/extract_*.py
/translate_*.py
/solve_*.py
/direct_*.py
/analyze_*.py
/find_*.py
/identify_*.py
/show_*.py
/tag_*.py
/tag_*.json
/update_*.py
/generate_*.py
/post_*.py
/cross_post_*.py
/final_*.py
/memory_tagger_*.py
/quick_test.sh
/emergency_repair.sh
/start_langgraph_*.sh
/final_*.sh

# Backup files
*.backup*
*backup-*
*backup.*

# Temporary/one-off outputs
/full_text.txt
/tagging_*.json
/moltbook_*.json
/*_info.json
/*_report.md
/*_post.md
/*_version.md
/*_POST.md
/*_VERSION.md

# Large binary files (PDFs, documents) - keep out of repo
/*.pdf
/*.docx
/*.doc

# Configuration backups (not needed in repo)
/heartbeat-state.json.backup*

# Test and simulation data (generated)
/simulations/hot_workspace/branches/*.json

# Generated embeddings (can be regenerated)
/memory/embeddings/*.npy
/memory/embeddings/memory_embeddings.json
/memory/embeddings/backups/
/memory/embeddings/*.backup*